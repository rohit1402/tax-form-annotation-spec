{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://com.example/schemas/field-annotation.schema.json",
    "title": "Tax Form Field Annotation Specification",
    "description": "Schema for an annotation file describing where values go on a tax form, how they are formatted, and which nested data they reference.",
    "type": "object",
    "required": [
        "schemaVersion",
        "formId",
        "formVersion",
        "pageDetails",
        "fields"
    ],
    "additionalProperties": false,
    "properties": {
        "schemaVersion": {
            "type": "string",
            "description": "Version of the schema",
            "pattern": "^\\d+\\.\\d+$"
        },
        "formId": {
            "type": "string",
            "description": "Unique identifier for the form template (e.g. irs-w2-2025, irs-1040-2025)"
        },
        "formVersion": {
            "type": "string",
            "description": "Tax year / revision, since forms can change annually"
        },
        "pageDetails": {
            "$ref": "#/$defs/PageDetails"
        },
        "fields": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/FieldAnnotation"
            }
        }
    },
    "$defs": {
        "Unit": {
            "type": "string",
            "enum": [
                "pt",
                "in",
                "mm",
                "px"
            ],
            "default": "pt"
        },
        "Origin": {
            "type": "string",
            "enum": [
                "top-left",
                "bottom-left"
            ],
            "default": "top-left"
        },
        "PageDetails": {
            "type": "object",
            "required": [
                "width",
                "height",
                "unit",
                "origin"
            ],
            "additionalProperties": false,
            "properties": {
                "width": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "height": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "unit": {
                    "$ref": "#/$defs/Unit"
                },
                "origin": {
                    "$ref": "#/$defs/Origin"
                }
            }
        },
        "Position": {
            "type": "object",
            "required": [
                "page",
                "x",
                "y",
                "width",
                "height"
            ],
            "additionalProperties": false,
            "properties": {
                "page": {
                    "type": "integer",
                    "minimum": 1
                },
                "x": {
                    "type": "number"
                },
                "y": {
                    "type": "number"
                },
                "width": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "height": {
                    "type": "number",
                    "exclusiveMinimum": 0
                }
            }
        },
        "Format": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "style": {
                    "type": "string",
                    "enum": [
                        "plain",
                        "currency",
                        "percent",
                        "date",
                        "ssn",
                        "ein",
                        "checkmark"
                    ]
                },
                "decimalPlaces": {
                    "type": "integer",
                    "minimum": 0
                },
                "thousandsSeparator": {
                    "type": "boolean"
                },
                "negativeStyle": {
                    "type": "string",
                    "enum": [
                        "minus",
                        "parentheses"
                    ]
                },
                "dateFormat": {
                    "type": "string"
                },
                "align": {
                    "type": "string",
                    "enum": [
                        "left",
                        "right",
                        "center"
                    ]
                },
                "fontSize": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "maxLines": {
                    "type": "integer",
                    "minimum": 1
                },
                "checkedSymbol": {
                    "type": "string"
                }
            }
        },
        "CheckboxOption": {
            "type": "object",
            "required": [
                "matchValue",
                "position"
            ],
            "additionalProperties": false,
            "properties": {
                "matchValue": {
                    "type": "string",
                    "description": "Value compared against the value resolved by the parent field's dataRef. If they match, this option is marked."
                },
                "position": {
                    "$ref": "#/$defs/Position"
                }
            }
        },
        "TemplateField": {
            "type": "object",
            "required": [
                "fieldId",
                "dataRef",
                "format"
            ],
            "additionalProperties": false,
            "properties": {
                "fieldId": {
                    "type": "string"
                },
                "dataRef": {
                    "type": "string",
                    "description": "Resolved relative to the current array item, not the document root."
                },
                "format": {
                    "$ref": "#/$defs/Format"
                },
                "offsetX": {
                    "type": "number",
                    "default": 0
                },
                "offsetY": {
                    "type": "number",
                    "default": 0
                }
            }
        },
        "BaseField": {
            "type": "object",
            "required": [
                "fieldId",
                "dataRef"
            ],
            "properties": {
                "fieldId": {
                    "type": "string"
                },
                "label": {
                    "type": "string",
                    "description": "Human-readable description; documentation only, not rendered."
                },
                "position": {
                    "$ref": "#/$defs/Position"
                },
                "dataRef": {
                    "type": "string",
                    "description": "JSONPath-style reference into the taxpayer data set. May be wrapped in sum(), count(), or first() for aggregation."
                },
                "format": {
                    "$ref": "#/$defs/Format"
                }
            }
        },
        "SimpleField": {
            "description": "text, currency, number, date, or checkbox fields — use exactly the base shape, no additional properties.",
            "allOf": [
                {
                    "$ref": "#/$defs/BaseField"
                }
            ],
            "type": "object",
            "unevaluatedProperties": false,
            "required": [
                "type",
                "position",
                "format"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "text",
                        "currency",
                        "number",
                        "date",
                        "checkbox"
                    ]
                }
            }
        },
        "CheckboxGroupField": {
            "description": "Mutually-exclusive checkbox options; one dataRef resolved once against a list of matchValues.",
            "allOf": [
                {
                    "$ref": "#/$defs/BaseField"
                }
            ],
            "type": "object",
            "unevaluatedProperties": false,
            "required": [
                "type",
                "options",
                "format"
            ],
            "properties": {
                "type": {
                    "const": "checkboxGroup"
                },
                "options": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/CheckboxOption"
                    }
                }
            }
        },
        "RepeatingGroupField": {
            "description": "A template of sub-fields stamped once per item in an array resolved by dataRef.",
            "allOf": [
                {
                    "$ref": "#/$defs/BaseField"
                }
            ],
            "type": "object",
            "unevaluatedProperties": false,
            "required": [
                "type",
                "position",
                "maxInstances",
                "rowHeight",
                "template"
            ],
            "properties": {
                "type": {
                    "const": "repeatingGroup"
                },
                "maxInstances": {
                    "type": "integer",
                    "minimum": 1
                },
                "rowHeight": {
                    "type": "number",
                    "exclusiveMinimum": 0
                },
                "template": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/TemplateField"
                    }
                }
            }
        },
        "FieldAnnotation": {
            "oneOf": [
                {
                    "$ref": "#/$defs/SimpleField"
                },
                {
                    "$ref": "#/$defs/CheckboxGroupField"
                },
                {
                    "$ref": "#/$defs/RepeatingGroupField"
                }
            ]
        }
    }
}